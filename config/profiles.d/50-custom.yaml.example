# Example custom profile showing every available field.
# Copy to a .yaml file in this directory (gitignored) and edit.
# Profiles are matched against the inserted SIM's ICCID; the best match wins:
#   exact match > longest matching prefix > lowest priority number > name.

name: my-special-sims
description: Example — Hologram profile type needing three PDP contexts and PAP auth

match:
  # Patterns are exact ICCIDs or prefixes ending in "*".
  iccid_patterns:
    - "8944500612345678901"   # one specific SIM
    - "8944502*"              # or a whole prefix range
  priority: 10                # lower number = higher precedence on ties

# The modem will be reconciled to EXACTLY these contexts (1-3):
# firmware-auto-created extras are deleted, mismatches corrected, missing ones defined.
pdp_contexts:
  - cid: 1
    apn: hologram
    pdp_type: IPv4v6
    auth: none
    bearer: true              # exactly one context must be the bearer
  - cid: 2
    apn: hologram.special
    pdp_type: IPv4
    auth: pap
    username: REPLACE_ME
    password: REPLACE_ME      # secrets are fine HERE because real profile files are gitignored
  - cid: 3
    apn: ims
    pdp_type: IPv4v6
    auth: none

# Optional: alternative PDP-context sets, tried in order if the primary
# pdp_contexts above doesn't attach + get an IP. Use this when the right
# context can't be known from the ICCID alone -- e.g. Verizon-direct SIMs
# whose context depends on the Hologram data plan. The daemon settles on the
# first set that connects.
pdp_variants:
  - name: plan-b
    pdp_contexts:
      - { cid: 1, apn: we01.vzwstatic, pdp_type: IPv4, bearer: true }

# Raw AT commands sent before connecting (vendor-specific tweaks, band locks, etc.)
at_init:
  - 'AT+QCFG="nwscanmode",0'

routing:
  make_default: true
  metric: 50

# Heartbeat/monitoring is a GLOBAL setting managed in the web UI ("Monitoring"
# tab) and applies to every SIM. Only include this `monitor` block if THIS
# profile must OVERRIDE the global config (e.g. a different endpoint for one
# SIM). When enabled here, it wins over the global config while this profile is
# active. Placeholders (URL/headers/body): {iccid} {imei} {imsi} {operator}
# {signal_rssi} {signal_percent} {ip_address} {hostname} {timestamp} {state}
# {profile_name} {status} {status_message}.
monitor:
  enabled: false
  # send_when_degraded: true   # keep sending while cellular is down
  # body: '{"iccid":"{iccid}","status":"{status}","ts":"{timestamp}"}'  # shared payload
  # destinations:              # one shared payload -> each endpoint over its interface
  #   - egress: cellular       # wlan (default) | cellular | auto (OS routes; LAN/VPN)
  #     method: POST
  #     url: "https://hooks.example.com/heartbeat"
  #     headers: { Authorization: "Bearer REPLACE_ME" }
  #     interval_seconds: 300
  #   - egress: wlan           # e.g. also post to a LAN endpoint over Wi-Fi
  #     url: "http://10.0.0.5/heartbeat"
  #     interval_seconds: 60

fallback_test:
  airplane_seconds: 900
