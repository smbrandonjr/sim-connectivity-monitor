# sim-monitor: reserve one spare AT-capable serial interface per modem.
#
# ID_MM_PORT_IGNORE=1  -> ModemManager never probes or claims the port
# SYMLINK sim-monitor-at -> stable device path regardless of ttyUSB numbering
#
# ModemManager controls these modems over QMI/MBIM (cdc-wdm0), so it does not
# need the interface we take. Numbered lower than MM's 80-mm-* rules.
#
# If your modem model is not listed, find the right interface number with:
#   udevadm info -q property -n /dev/ttyUSBx | grep ID_USB_INTERFACE_NUM
# and check which ports MM claimed with:  mmcli -m 0 | grep -i ports
# Then add a rule following the same pattern and run:
#   sudo udevadm control --reload-rules && sudo udevadm trigger --subsystem-match=tty

# ---- Quectel (VID 2c7c) ----
# EC25 / EG25-G: if00 DM, if01 NMEA, if02 AT (MM candidate), if03 modem/PPP <- ours
SUBSYSTEM=="tty", ATTRS{idVendor}=="2c7c", ATTRS{idProduct}=="0125", ENV{ID_USB_INTERFACE_NUM}=="03", ENV{ID_MM_PORT_IGNORE}="1", SYMLINK+="sim-monitor-at"
# EC21
SUBSYSTEM=="tty", ATTRS{idVendor}=="2c7c", ATTRS{idProduct}=="0121", ENV{ID_USB_INTERFACE_NUM}=="03", ENV{ID_MM_PORT_IGNORE}="1", SYMLINK+="sim-monitor-at"
# BG96: if02 AT command port <- ours (MM uses if03 + QMI)
SUBSYSTEM=="tty", ATTRS{idVendor}=="2c7c", ATTRS{idProduct}=="0296", ENV{ID_USB_INTERFACE_NUM}=="02", ENV{ID_MM_PORT_IGNORE}="1", SYMLINK+="sim-monitor-at"

# ---- SIMCOM (VID 1e0e) ----
# SIM7600: if00 diag, if01 NMEA, if02 AT (MM candidate), if03 modem/PPP <- ours
SUBSYSTEM=="tty", ATTRS{idVendor}=="1e0e", ATTRS{idProduct}=="9001", ENV{ID_USB_INTERFACE_NUM}=="03", ENV{ID_MM_PORT_IGNORE}="1", SYMLINK+="sim-monitor-at"
SUBSYSTEM=="tty", ATTRS{idVendor}=="1e0e", ATTRS{idProduct}=="9011", ENV{ID_USB_INTERFACE_NUM}=="03", ENV{ID_MM_PORT_IGNORE}="1", SYMLINK+="sim-monitor-at"

# ---- Telit (VID 1bc7) ----
# LE910C1/C4: if04 is a spare AT port in the default composition; verify on
# your unit (Telit compositions vary with AT#USBCFG).
SUBSYSTEM=="tty", ATTRS{idVendor}=="1bc7", ATTRS{idProduct}=="1201", ENV{ID_USB_INTERFACE_NUM}=="04", ENV{ID_MM_PORT_IGNORE}="1", SYMLINK+="sim-monitor-at"
SUBSYSTEM=="tty", ATTRS{idVendor}=="1bc7", ATTRS{idProduct}=="0036", ENV{ID_USB_INTERFACE_NUM}=="04", ENV{ID_MM_PORT_IGNORE}="1", SYMLINK+="sim-monitor-at"
