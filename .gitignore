# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.venv/
.pytest_cache/
.ruff_cache/
.coverage

# Node / frontend build tooling (the built SPA under src/sim_monitor/web/spa IS committed)
frontend/node_modules/
frontend/.vite/
npm-debug.log*
# Ship only woff2 fonts in the built SPA; drop the bulky legacy fallbacks
# (modern browsers use woff2 — saves ~4.5 MB of icon-font formats in the repo).
src/sim_monitor/web/spa/assets/*.svg
src/sim_monitor/web/spa/assets/*.eot
src/sim_monitor/web/spa/assets/*.ttf
src/sim_monitor/web/spa/assets/*.woff

# IDE
.idea/
.vscode/

# Local runtime data
*.db
*.db-journal

# Real configs may contain secrets (tokens, APN credentials) — never commit them.
# Only example files and the secret-free Hologram default profile are tracked.
config/config.yaml
config/profiles.d/*.yaml
!config/profiles.d/00-hologram-default.yaml
*.local.yaml

/COMPANION-APP-THEME-GUIDE.md
# local smoke-test logs
sim_err.log
sim_out.log

# personal scratch notes
working-notes.md
